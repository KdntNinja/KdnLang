let hello: str = "Hello";
print(hello);
print("Starting condition check...");

// Debug the actual value of the hello variable
print("Debug - hello variable value: " + hello);
print("Debug - hello variable type: str");
print("Debug - comparing with: Hello");

if (hello == "Hello") {
    print("Inside if block - condition was true!");
    let name: str = input("Enter your name: ");
    print("Hello, " + name + "!");
} else {
    print("Inside else block - condition was false!");
    print("Expected 'Hello' but got: " + hello);
}