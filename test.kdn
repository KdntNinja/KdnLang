// Basic variable declarations
let name: str = "John Doe";
let age: i32 = 30;
let height: f64 = 182.5;

// Function calls
print("Welcome to KDN Language!");
print("User: " + name);

// Math operations
let double_age: i32 = age * 2;
let half_height: f64 = height / 2;

// Nested expressions
let complex_value: i32 = (age + 10) * 2 - 5;

// Block scope
{
    let temp: i32 = 100;
    print("Inside block: " + str(temp));
}

// Method chaining
let uppercase_name: str = name.to_uppercase();

// String operations
let greeting: str = "Hello, " + name + "! You are " + str(age) + " years old.";

// Input with parsing
let user_input: str = input("Enter a number: ");
let parsed_value: i32 = user_input.parse();
print("You entered: " + str(parsed_value));

// Conditional example (if supported)
match parsed_value {
    "0" => print("You entered zero"),
    "1" => print("You entered one"),
    _ => print("You entered something else")
}