// filepath: examples/hello.kdn
// Hello World program in KdnLang
// This demonstrates the strongly-typed, compiled nature of the language

fn main() -> none {
    // All strings must be explicitly typed
    let message: str = "Hello, world!";
    print(message);
    
    // Numeric operations with typed variables
    let x: i32 = 10;
    let y: i32 = 20;
    let sum: i32 = x + y;
    
    print("The sum is: " + sum.to_string());
}