// Define basic building blocks
digit = _{ '0'..'9' }
letter = _{ 'a'..'z' | 'A'..'Z' }
identifier = @{ letter ~ (letter | digit | "_")* }
number = @{ digit+ }
string_literal = @{ "\"" ~ (!"\"" ~ ANY)* ~ "\"" | "'" ~ (!"'" ~ ANY)* ~ "'" }

// Define operators and punctuation
operator = { "+" | "-" | "*" | "/" }
punctuation = { "=" | ";" }

// Define type_keyword rule
type_keyword = { "str" | "i32" | "f64" }

// Add function call pattern
function_call = { identifier ~ "(" ~ (expression ~ ("," ~ expression)*)? ~ ")" }

// Define expression rules
primary_expression = { number | string_literal | function_call | identifier }
expression = { primary_expression ~ (operator ~ primary_expression)* }

// Update assignment rule to include 'let' keyword and semicolon
assignment = { "let" ~ identifier ~ ":" ~ type_keyword ~ "=" ~ expression ~ ";" }

// Define function rule (no semicolon needed for blocks)
function = { "fn" ~ identifier ~ "(" ~ (identifier ~ ":" ~ type_keyword ~ ("," ~ identifier ~ ":" ~ type_keyword)*)? ~ ")" ~ block }

// Define block rule
block = { "{" ~ statement* ~ "}" }

// Define match statement rule
match_statement = { "match" ~ expression ~ "{" ~ (expression ~ "=>" ~ statement ~ ",")* ~ "_" ~ "=>" ~ statement ~ "}" }

// Define try-except rule
try_except = { "try" ~ block ~ "except" ~ block }

// Expressions that need to be terminated with semicolons
expression_statement = { expression ~ ";" }

// Update statement rule to include semicolons
statement = _{ 
    assignment | 
    expression_statement | 
    function | 
    match_statement | 
    try_except |
    block
}

// Define top-level constructs
program = { SOI ~ statement* ~ EOI }

// Skip whitespace and comments
WHITESPACE = _{ " " | "\t" | "\n" | "//" ~ (!"\n" ~ ANY)* ~ "\n" }