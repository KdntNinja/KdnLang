// Basic tokens
WHITESPACE = _{ " " | "\t" | "\n" | "\r" }
COMMENT = _{ "//" ~ (!"\n" ~ ANY)* ~ "\n" }

// Identifiers and literals
identifier = @{ (ASCII_ALPHA | "_") ~ (ASCII_ALPHANUMERIC | "_")* }
int_lit = @{ ASCII_DIGIT+ }
float_lit = @{ ASCII_DIGIT+ ~ "." ~ ASCII_DIGIT+ }
number = @{ float_lit | int_lit }
string_lit = @{ "\"" ~ (!"\"" ~ ANY)* ~ "\"" | "'" ~ (!"\'" ~ ANY)* ~ "'" }
bool_lit = @{ "true" | "false" }

// Type system
type_name = { "int" | "float" | "string" | "str" | "bool" | "void" | identifier }
type_annotation = { ":" ~ type_name }

// Operators
comparison_op = { "==" | "!=" | "<" | "<=" | ">" | ">=" }
arithmetic_op = { "+" | "-" | "*" | "/" | "%" }
logical_op = { "&&" | "||" | "!" }
assignment_op = { "=" }
operator = { comparison_op | arithmetic_op | logical_op | assignment_op }

// Expressions
literal = { number | string_lit | bool_lit }
primary_expr = { literal | identifier | "(" ~ expr ~ ")" | function_call }
function_call = { identifier ~ "(" ~ (expr ~ ("," ~ expr)*)? ~ ")" }
unary_expr = { logical_op? ~ primary_expr }
multiplicative_expr = { unary_expr ~ (arithmetic_op ~ unary_expr)* }
additive_expr = { multiplicative_expr ~ (arithmetic_op ~ multiplicative_expr)* }
comparison_expr = { additive_expr ~ (comparison_op ~ additive_expr)* }
logical_expr = { comparison_expr ~ (logical_op ~ comparison_expr)* }
expr = { logical_expr }

// Python-style print statement (without parentheses)
print_statement = { "print" ~ expr ~ ";" }

// Statements - ensure all statement types that should end with semicolons do so
var_decl = { "let" ~ identifier ~ type_annotation? ~ assignment_op ~ expr ~ ";" }
assignment = { identifier ~ assignment_op ~ expr ~ ";" }
expr_statement = { expr ~ ";" }  // All expression statements must end with semicolons
return_statement = { "return" ~ expr? ~ ";" }

// Function parameters
param = { identifier ~ type_annotation? }
param_list = { (param ~ ("," ~ param)*)? }

// Structure definition parts
struct_field = { identifier ~ type_annotation ~ ";" }

// Control flow statements don't need semicolons
if_statement = { 
    "if" ~ "(" ~ expr ~ ")" ~ block ~ 
    ("else" ~ "if" ~ "(" ~ expr ~ ")" ~ block)* ~ 
    ("else" ~ block)? 
}
while_statement = { "while" ~ "(" ~ expr ~ ")" ~ block }

// Block statements don't need semicolons
block = { "{" ~ statement* ~ "}" }

// Function and struct definitions don't need semicolons
function_def = { "fn" ~ identifier ~ "(" ~ param_list ~ ")" ~ type_annotation? ~ block }
struct_def = { "struct" ~ identifier ~ "{" ~ struct_field* ~ "}" }

// Match arm expressions in blocks don't need semicolons, but expressions followed by semicolons do
match_arm = { expr ~ "=>" ~ (block | expr ~ ";") }
match_statement = { "match" ~ expr ~ "{" ~ match_arm+ ~ "}" }

// Top-level statements
statement = {
    var_decl |
    assignment |
    if_statement |
    while_statement |
    function_def |
    struct_def |
    match_statement |
    return_statement |
    print_statement |
    expr_statement |
    block
}

// Program is a sequence of statements
program = { SOI ~ statement* ~ EOI }